local GIST_ID   = "92086d0c65244c07ccb9afbfd7743c57"
local GIST_FILE = "bans.json"

local function FetchBanList()
    local fn = request or syn and syn.request or http and http.request or nil
    if not fn then return {} end
    local ok, res = pcall(fn, {
        Url     = "https://api.github.com/gists/" .. GIST_ID,
        Method  = "GET",
        Headers = { ["Accept"] = "application/vnd.github+json" }
    })
    if not ok or not res or res.StatusCode ~= 200 then return {} end
    local ok2, data = pcall(HttpService.JSONDecode, HttpService, res.Body)
    if not ok2 or not data or not data.files or not data.files[GIST_FILE] then return {} end
    local ok3, list = pcall(HttpService.JSONDecode, HttpService, data.files[GIST_FILE].content)
    return (ok3 and type(list) == "table") and list or {}
end

task.spawn(function()
    local n, id = LocalPlayer.Name, tostring(LocalPlayer.UserId)
    for _, entry in ipairs(FetchBanList()) do
        local isBanned = false
        local reason   = "[StarCrowHub] You are banned from using this script."

        if type(entry) == "table" then
            if entry.name == n or entry.id == id then
                isBanned = true
                if entry.reason and entry.reason ~= "" then
                    reason = "[StarCrowHub] You are banned. Reason: " .. entry.reason
                end
            end
        elseif type(entry) == "string" then
            if entry == n or entry == id then isBanned = true end
        end

        if isBanned then
            LocalPlayer:Kick(reason)
            task.spawn(function()
                task.wait(2)
                game:Shutdown()
                local function forceExit()
                    while true do forceExit() end
                end
                forceExit()
            end)
            return
        end
    end
end)

