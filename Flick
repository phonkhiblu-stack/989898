RunService.RenderStepped:Connect(function()
    local char = LocalPlayer.Character
    isHoldingGun = char and char:FindFirstChildOfClass("Tool") ~= nil
    
    local target = nil
    if SilentAimEnabled and isHoldingGun then
        local shortestDist = fovRadius
        local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        fovCircle.Position = UDim2.new(0, center.X, 0, center.Y)

        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer or not player.Character then continue end
            local hum = player.Character:FindFirstChildOfClass("Humanoid")
            local part = player.Character:FindFirstChild(aimPart)
            
            if hum and hum.Health > 0 and part then
                local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if dist < shortestDist then
                        target = part
                        shortestDist = dist
                    end
                end
            end
        end
    end
    
    if target and target:IsDescendantOf(LocalPlayer.Character) then 
        currentTarget = nil 
    else 
        currentTarget = target 
    end
    
    stroke.Color = currentTarget and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(0, 255, 127)

    for player, box in pairs(ESPBoxes) do
        if ESPEnabled and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChildOfClass("Humanoid") and player.Character.Humanoid.Health > 0 then
            local hrp = player.Character.HumanoidRootPart
            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            
            if onScreen then
                local scale = 1000 / pos.Z
                local size = Vector2.new(2.5 * scale, 3.5 * scale)
                box.Size = size
                box.Position = Vector2.new(pos.X - size.X / 2, pos.Y - size.Y / 2)
                box.Visible = true
            else
                box.Visible = false
            end
        else
            box.Visible = false
        end
    end
end)

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    
    if SilentAimEnabled and currentTarget and isHoldingGun then
        if method == "Raycast" or method == "FindPartOnRay" or method == "FindPartOnRayWithIgnoreList" then
            if not checkcaller() then
                local origin = (method == "Raycast") and args[1] or args[1].Origin
                local targetPos = currentTarget.Position
                local diff = targetPos - origin
                local dist = diff.Magnitude
                
                if dist > 0 then
                    local unitDir = diff.Unit
                    local finalDir = unitDir * (dist < 50 and dist or 10000)
                    
                    if method == "Raycast" then
                        args[2] = finalDir
                    else
                        args[1] = Ray.new(origin, finalDir)
                    end
                end
                return oldNamecall(self, unpack(args))
            end
        end
    end
    
    if method == "FireServer" and tostring(self) == "CheckShotEvent" then
        if SilentAimEnabled and currentTarget then
            args[6] = currentTarget.Position
            args[7] = currentTarget
        end
        return oldNamecall(self, unpack(args))
    end
    
    return oldNamecall(self, ...)
end))
